# OrangeHRM Automation Framework - Environment Configuration
# Copy this file to .env and update values for your environment

# ===== Application URLs =====
BASE_URL=https://opensource-demo.orangehrmlive.com/web/index.php
ENVIRONMENT=dev

# DEV Environment
# STAGING_URL=https://staging.orangehrm.example.com/web/index.php
# PROD_URL=https://prod.orangehrm.example.com/web/index.php

# ===== Credentials =====
# IMPORTANT: Use environment variables instead of hardcoding credentials
ADMIN_USER=Admin
ADMIN_PASSWORD=admin123

# Staging/Prod Overrides
# STAGING_ADMIN_USER=admin_staging
# STAGING_ADMIN_PASSWORD=password_staging
# PROD_ADMIN_USER=admin_prod
# PROD_ADMIN_PASSWORD=password_prod

# ===== Browser Configuration =====
HEADLESS=False
DEFAULT_TIMEOUT=20000
NAVIGATION_TIMEOUT=30000
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080
SLOW_MO=0

# ===== Retry Configuration =====
MAX_RETRIES=3
RETRY_DELAY=500

# ===== Paths =====
DOWNLOADS_DIR=downloads
REPORTS_DIR=reports
LOGS_DIR=logs
VIDEOS_DIR=videos
SCREENSHOTS_DIR=screenshots
RESOURCES_DIR=resources
STORAGE_FILE=auth.json

# ===== Logging =====
LOG_LEVEL=INFO

# ===== Allure Reporting =====
ALLURE_CLEAN_START=true
